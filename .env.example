# === AI ===
OPENAI_API_KEY=sk-xxx          # GPT-5.5 (free credits from buildathon)
HERMES_MODEL=openai/gpt-5.5    # or mimo-v2.5-pro for local

# === SHOPIFY ===
SHOPIFY_STORE_DOMAIN=hermesstore-demo.myshopify.com
SHOPIFY_CLIENT_ID=xxx
SHOPIFY_CLIENT_SECRET=xxx
SHOPIFY_API_VERSION=2026-04

# === DATABASE ===
CONVEX_URL=https://xxx.convex.cloud    # Convex (real-time)
# OR use SQLite for local dev (no config needed)

# === HOSTING ===
CLOUDFLARE_API_TOKEN=xxx       # For deploying to Cloudflare Pages
CLOUDFLARE_ACCOUNT_ID=xxx

# === PAYMENTS ===
DODO_API_KEY=xxx               # Dodo Payments (₹9 transactions)
RAZORPAY_KEY_ID=xxx            # Backup: Razorpay
RAZORPAY_KEY_SECRET=xxx

# === VOICE ===
ELEVENLABS_API_KEY=xxx         # Voice synthesis
# Wispr Flow runs as desktop app (no API key needed)

# === COMPETITOR INTEL ===
LINKUP_API_KEY=xxx             # Competitor data & intent signals

# === EMAIL ===
RESEND_API_KEY=re_xxx          # Email automation

# === SHIPPING ===
SHIPROCKET_EMAIL=xxx           # India shipping aggregator
SHIPROCKET_PASSWORD=xxx

# === MEMORY ===
AGENTMEMORY_URL=http://localhost:3111   # Persistent agent memory
